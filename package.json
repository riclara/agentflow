{
  "name": "@riclara/agentflow",
  "version": "1.0.6",
  "description": "Configure a multi-agent development workflow across Claude Code, Codex, Cowork, and OpenCode.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riclara/agentflow.git"
  },
  "homepage": "https://github.com/riclara/agentflow#readme",
  "bugs": {
    "url": "https://github.com/riclara/agentflow/issues"
  },
  "type": "module",
  "bin": {
    "agentflow": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "schema.json",
    "README.md",
    "README.es.md",
    "LICENSE"
